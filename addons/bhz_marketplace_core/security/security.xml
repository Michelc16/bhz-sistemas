<odoo>
  <record id="group_marketplace_manager" model="res.groups">
    <field name="name">Marketplace Manager</field>
    <field name="implied_ids" eval="[(4, ref('base.group_system')), (4, ref('bhz_marketplace_core.group_marketplace_seller'))]"/>
  </record>
  <record id="group_marketplace_seller" model="res.groups">
    <field name="name">Marketplace Seller</field>
    <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
  </record>

  <!-- Admin (group_system) carrega automaticamente o grupo de manager do marketplace -->
  <record id="base.group_system" model="res.groups">
    <field name="implied_ids" eval="[(4, ref('bhz_marketplace_core.group_marketplace_manager'))]"/>
  </record>
</odoo>
