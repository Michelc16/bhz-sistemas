<odoo>
  <record id="action_bhz_app_sellers" model="ir.actions.act_window">
    <field name="name">Sellers</field>
    <field name="res_model">bhz.marketplace.seller</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_products" model="ir.actions.act_window">
    <field name="name">Produtos Marketplace</field>
    <field name="res_model">product.template</field>
    <field name="domain">[('bhz_seller_id', '!=', False)]</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_orders" model="ir.actions.act_window">
    <field name="name">Pedidos Marketplace</field>
    <field name="res_model">sale.order</field>
    <field name="domain">[('order_line.bhz_seller_id', '!=', False)]</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_shipments" model="ir.actions.act_window">
    <field name="name">Envios</field>
    <field name="res_model">bhz.seller.shipment</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_returns" model="ir.actions.act_window">
    <field name="name">Devoluções/Disputas</field>
    <field name="res_model">bhz.marketplace.return</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_payouts" model="ir.actions.act_window">
    <field name="name">Repasses</field>
    <field name="res_model">bhz.seller.payout</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_reputation" model="ir.actions.act_window">
    <field name="name">Reputação</field>
    <field name="res_model">bhz.seller.reputation</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_ads" model="ir.actions.act_window">
    <field name="name">Ads</field>
    <field name="res_model">bhz.product.ads</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_questions" model="ir.actions.act_window">
    <field name="name">Perguntas</field>
    <field name="res_model">bhz.product.question</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_connectors_accounts" model="ir.actions.act_window">
    <field name="name">Contas de Integração</field>
    <field name="res_model">bhz.connector.account</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_connectors_jobs" model="ir.actions.act_window">
    <field name="name">Jobs de Integração</field>
    <field name="res_model">bhz.connector.job</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_marketplace_home" model="ir.actions.act_window">
    <field name="name">BHZ Marketplace</field>
    <field name="res_model">bhz.marketplace.seller</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_bhz_app_settings" model="ir.actions.act_window">
    <field name="name">Configuração do Marketplace</field>
    <field name="res_model">res.config.settings</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="context">{'module_bhz_marketplace_core': True}</field>
  </record>
</odoo>
