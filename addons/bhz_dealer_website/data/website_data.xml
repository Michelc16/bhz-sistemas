<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Página home publicada usando o template QWeb do módulo -->
    <record id="bhz_dealer_homepage" model="website.page">
      <field name="name">BHZ Dealer Home</field>
      <field name="url">/</field>
      <field name="view_id" ref="bhz_dealer_website.view_page_dealer_home"/>
      <field name="website_published">True</field>
      <field name="website_id" ref="website.default_website"/>
      <field name="is_homepage">True</field>
    </record>

    <!-- Menu principal do site -->
    <record id="menu_bhz_dealer_home" model="website.menu">
      <field name="name">Home</field>
      <field name="url">/</field>
      <field name="parent_id" ref="website.main_menu"/>
      <field name="sequence">5</field>
      <field name="website_id" ref="website.default_website"/>
    </record>

    <record id="menu_bhz_dealer_stock" model="website.menu">
      <field name="name">Estoque</field>
      <field name="url">/carros</field>
      <field name="parent_id" ref="website.main_menu"/>
      <field name="sequence">10</field>
      <field name="website_id" ref="website.default_website"/>
    </record>
  </data>
</odoo>
