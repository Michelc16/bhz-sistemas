    <!-- Páginas institucionais demo (ligadas ao website padrão) -->
    <record id="view_demo_guarantee" model="ir.ui.view">
      <field name="name">bhz.dealer.demo.guarantee</field>
      <field name="type">qweb</field>
      <field name="arch" type="xml">
        <template name="Garantia Dealer" page="True">
          <t t-call="website.layout">
            <div id="wrap" class="container py-5">
              <h1 class="mb-3">Garantia Estendida</h1>
              <p class="lead">Nosso estoque passa por inspeção e entrega com garantia.</p>
              <ul>
                <li>Laudo cautelar aprovado.</li>
                <li>Garantia de motor e câmbio.</li>
                <li>Assistência para transferência.</li>
              </ul>
            </div>
          </t>
        </template>
      </field>
    </record>

    <record id="page_demo_guarantee" model="website.page">
      <field name="name">Garantia</field>
      <field name="website_id" ref="website.default_website"/>
      <field name="url">/garantia</field>
      <field name="view_id" ref="view_demo_guarantee"/>
      <field name="is_published">True</field>
    </record>

    <record id="view_demo_financing" model="ir.ui.view">
      <field name="name">bhz.dealer.demo.financing</field>
      <field name="type">qweb</field>
      <field name="arch" type="xml">
        <template name="Financiamento Dealer" page="True">
          <t t-call="website.layout">
            <div id="wrap" class="container py-5">
              <h1 class="mb-3">Financiamento fácil</h1>
              <p class="lead">Simule e aprove com nossos parceiros.</p>
              <p>Taxas competitivas, aprovação online e análise rápida.</p>
            </div>
          </t>
        </template>
      </field>
    </record>

