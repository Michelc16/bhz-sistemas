<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_bhz_dealer_config_tree" model="ir.ui.view">
      <field name="name">bhz.dealer.website.config.tree</field>
      <field name="type">list</field>
      <field name="model">bhz.dealer.website.config</field>
      <field name="arch" type="xml">
        <list string="Configurações do site">
          <field name="website_id"/>
          <field name="dealer_enabled"/>
          <field name="dealer_primary_color"/>
          <field name="dealer_secondary_color"/>
          <field name="whatsapp_number"/>
        </list>
      </field>
    </record>

    <record id="view_bhz_dealer_config_form" model="ir.ui.view">
      <field name="name">bhz.dealer.website.config.form</field>
      <field name="model">bhz.dealer.website.config</field>
      <field name="arch" type="xml">
        <form string="Configuração do Website">
          <sheet>
            <group>
              <field name="website_id"/>
              <group>
                <field name="dealer_enabled"/>
                <field name="reveal_phone"/>
              </group>
              <group>
                <field name="dealer_primary_color" widget="color"/>
                <field name="dealer_secondary_color" widget="color"/>
              </group>
            </group>
            <notebook>
              <page string="Hero">
                <group>
                  <field name="hero_title"/>
                  <field name="hero_subtitle"/>
                  <field name="hero_bg_image" widget="image"/>
                </group>
              </page>
              <page string="Contato">
                <group>
                  <field name="phone"/>
                  <field name="whatsapp_number"/>
                  <field name="cta_label"/>
                  <field name="address"/>
                  <field name="instagram_url"/>
                </group>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>
