<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Página Home -->
    <record id="view_page_dealer_home" model="ir.ui.view">
      <field name="name">bhz.dealer.page.dealer.home</field>
      <field name="type">qweb</field>
      <field name="key">bhz_dealer_website.page_dealer_home</field>
      <field name="arch" type="xml">
        <template id="page_dealer_home" name="Dealer Home" page="True">
          <t t-call="website.layout">
            <t t-set="config" t-value="request.env['bhz.dealer.website.config'].sudo().get_for_website(request.website)"/>
            <t t-set="primary" t-value="config.primary_color or '#0d6efd'"/>
            <t t-set="secondary" t-value="config.secondary_color or '#6610f2'"/>
            <div id="wrap" class="bhz-dealer"
                 t-att-style="'--bhz-primary:%s;--bhz-secondary:%s;' % (primary, secondary)"
                 t-att-data-bhz-whatsapp="(config.whatsapp or config.phone) and (config.whatsapp or config.phone) or ''"
                 t-att-data-bhz-whatsapp-msg="'Olá, quero saber mais sobre os carros.'">
              <section class="s_title py-5">
                <div class="container">
                  <div class="row align-items-center g-4">
                    <div class="col-lg-7">
                      <p class="text-uppercase text-muted mb-2">Sem burocracia • Revisados • Garantia</p>
                      <h1 class="display-5 fw-bold"><t t-esc="config.hero_title or 'Encontre o próximo carro da sua garagem.'"/></h1>
                      <p class="lead text-muted"><t t-esc="config.hero_subtitle or 'Busque por marca, ano ou faixa de preço e veja os destaques selecionados.'"/></p>
                    </div>
                    <div class="col-lg-5">
                      <t t-set="brand_list" t-value="request.env['bhz.dealer.car'].sudo().search_read([('active','=',True),('website_id','=',request.website.id)], ['brand'])"/>
                      <t t-set="brands" t-value="sorted({b['brand'] for b in brand_list if b.get('brand')})"/>
                      <form action="/carros" method="get" class="card shadow-sm p-3">
                        <div class="mb-2">
                          <label class="form-label">Marca</label>
                          <select class="form-select" name="brand">
                            <option value="">Todas</option>
                            <t t-foreach="brands" t-as="b">
                              <option t-att-value="b"><t t-esc="b"/></option>
                            </t>
                          </select>
                        </div>
                        <div class="row g-2 mb-2">
                          <div class="col-6">
                            <label class="form-label">Ano mín</label>
                            <input class="form-control" type="number" name="year_min" placeholder="2015"/>
                          </div>
                          <div class="col-6">
                            <label class="form-label">Ano máx</label>
                            <input class="form-control" type="number" name="year_max" placeholder="2024"/>
                          </div>
                        </div>
                        <div class="mb-3">
                          <label class="form-label">Preço máximo</label>
                          <input class="form-control" type="number" name="price_max" placeholder="100000"/>
                        </div>
                        <div class="d-grid">
                          <button class="btn btn-primary btn-lg" type="submit">Buscar agora</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </section>

              <section class="py-5 bg-light" t-att-style="config.hero_bg_image and ('background-image:url(/web/image/%s/hero_bg_image); background-size:cover; background-position:center;' % config.id) or ''">
                <div class="container">
                  <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h3 mb-0">Destaques</h2>
                    <a class="btn btn-link" href="/carros">Ver estoque →</a>
                  </div>
                  <t t-set="featured" t-value="request.env['bhz.dealer.car'].sudo().search([('active','=',True),('is_featured','=',True),('website_id','=',request.website.id)], limit=8)"/>
                  <div class="row g-3">
                    <t t-if="featured">
                      <t t-foreach="featured" t-as="car">
                        <div class="col-md-6 col-lg-4 col-xl-3">
                          <t t-call="bhz_dealer_website.car_card"/>
                        </div>
                      </t>
                    </t>
                    <t t-else="">
                      <div class="col-12">
                        <div class="alert alert-info mb-0">Nenhum destaque disponível. Marque alguns carros como destaque para aparecer aqui.</div>
                      </div>
                    </t>
                  </div>
                </div>
              </section>

              <section class="py-5">
                <div class="container text-center">
                  <h3 class="mb-3">Quer ver o estoque completo?</h3>
                  <p class="text-muted mb-4">Acesse todos os carros disponíveis e filtre por marca, ano e preço.</p>
                  <a class="btn btn-primary btn-lg" href="/carros">Ver estoque</a>
                </div>
              </section>
            </div>
          </t>
        </template>
      </field>
    </record>

    <!-- Página de listagem -->
    <record id="view_page_cars_listing" model="ir.ui.view">
      <field name="name">bhz.dealer.page.cars.listing</field>
      <field name="type">qweb</field>
      <field name="key">bhz_dealer_website.page_cars_listing</field>
      <field name="arch" type="xml">
        <template id="page_cars_listing" name="Cars Listing" page="True">
          <t t-call="website.layout">
            <div id="wrap" class="bhz-dealer">
              <section class="bhz-section bhz-stock">
                <div class="container">
                  <div class="bhz-section-head">
                    <h1>Estoque</h1>
                    <div class="bhz-muted"><t t-esc="len(cars)"/> resultado(s)</div>
                  </div>

                  <div class="bhz-stock-layout">
                    <!-- Filtros -->
                    <aside class="bhz-filters">
                      <form action="/carros" method="get" class="bhz-filter-form">
                        <label>Busca</label>
                        <input class="form-control" type="text" name="q" t-att-value="filters.get('q') or ''"/>

                        <label class="mt-2">Ordenar por</label>
                        <select class="form-select" name="sort">
                          <option value="">Relevância</option>
                          <option value="price_asc" t-att-selected="1 if filters.get('sort')=='price_asc' else None">Preço (menor → maior)</option>
                          <option value="price_desc" t-att-selected="1 if filters.get('sort')=='price_desc' else None">Preço (maior → menor)</option>
                          <option value="year_desc" t-att-selected="1 if filters.get('sort')=='year_desc' else None">Ano (mais novo)</option>
                          <option value="year_asc" t-att-selected="1 if filters.get('sort')=='year_asc' else None">Ano (mais antigo)</option>
                        </select>

                        <label class="mt-2">Marca</label>
                        <select class="form-select" name="brand">
                          <option value="">Todas</option>
                          <t t-foreach="brand_list" t-as="b">
                            <option t-att-value="b" t-att-selected="1 if (filters.get('brand')==b) else None"><t t-esc="b"/></option>
                          </t>
                        </select>

                        <label class="mt-2">Condição</label>
                        <select class="form-select" name="condition">
                          <option value="">Todas</option>
                          <option value="new" t-att-selected="1 if filters.get('condition')=='new' else None">Novo</option>
                          <option value="seminovo" t-att-selected="1 if filters.get('condition')=='seminovo' else None">Seminovo</option>
                          <option value="used" t-att-selected="1 if filters.get('condition')=='used' else None">Usado</option>
                        </select>

                        <label class="mt-2">Combustível</label>
                        <select class="form-select" name="fuel">
                          <option value="">Todos</option>
                          <option value="flex" t-att-selected="1 if filters.get('fuel')=='flex' else None">Flex</option>
                          <option value="gasoline" t-att-selected="1 if filters.get('fuel')=='gasoline' else None">Gasolina</option>
                          <option value="ethanol" t-att-selected="1 if filters.get('fuel')=='ethanol' else None">Etanol</option>
                          <option value="diesel" t-att-selected="1 if filters.get('fuel')=='diesel' else None">Diesel</option>
                          <option value="hybrid" t-att-selected="1 if filters.get('fuel')=='hybrid' else None">Híbrido</option>
                          <option value="electric" t-att-selected="1 if filters.get('fuel')=='electric' else None">Elétrico</option>
                        </select>

                        <label class="mt-2">Câmbio</label>
                        <select class="form-select" name="transmission">
                          <option value="">Todos</option>
                          <option value="manual" t-att-selected="1 if filters.get('transmission')=='manual' else None">Manual</option>
                          <option value="auto" t-att-selected="1 if filters.get('transmission')=='auto' else None">Automático</option>
                          <option value="cvt" t-att-selected="1 if filters.get('transmission')=='cvt' else None">CVT</option>
                        </select>

                        <div class="row mt-2">
                          <div class="col-6">
                            <label>Ano mín</label>
                            <input class="form-control" type="number" name="year_min" t-att-value="filters.get('year_min') or ''"/>
                          </div>
                          <div class="col-6">
                            <label>Ano máx</label>
                            <input class="form-control" type="number" name="year_max" t-att-value="filters.get('year_max') or ''"/>
                          </div>
                        </div>

                        <div class="row mt-2">
                          <div class="col-6">
                            <label>Preço mín</label>
                            <input class="form-control" type="number" step="0.01" name="price_min" t-att-value="filters.get('price_min') or ''"/>
                          </div>
                          <div class="col-6">
                            <label>Preço máx</label>
                            <input class="form-control" type="number" step="0.01" name="price_max" t-att-value="filters.get('price_max') or ''"/>
                          </div>
                        </div>

                        <button class="btn btn-primary w-100 mt-3" type="submit">Aplicar filtros</button>
                        <a class="btn btn-outline-secondary w-100 mt-2" href="/carros">Limpar</a>
                      </form>
                    </aside>

                    <!-- Grid -->
                    <div class="bhz-stock-grid">
                      <div class="bhz-grid">
                        <t t-foreach="cars" t-as="car">
                          <t t-call="bhz_dealer_website.car_card"/>
                        </t>
                      </div>

                      <t t-if="not cars">
                        <div class="alert alert-info mt-3">Nenhum carro encontrado com esses filtros.</div>
                      </t>
                    </div>
                  </div>
                </div>
              </section>
            </div>
          </t>
        </template>
      </field>
    </record>

    <!-- Página de detalhe -->
    <record id="view_page_car_detail" model="ir.ui.view">
      <field name="name">bhz.dealer.page.car.detail</field>
      <field name="type">qweb</field>
      <field name="key">bhz_dealer_website.page_car_detail</field>
      <field name="arch" type="xml">
        <template id="page_car_detail" name="Car Detail" page="True">
          <t t-call="website.layout">
            <div id="wrap" class="bhz-dealer">
              <section class="bhz-section">
                <div class="container">
                  <div class="bhz-breadcrumb">
                    <a href="/carros">← Voltar ao estoque</a>
                  </div>

                  <div class="bhz-detail">
                    <div class="bhz-detail-media">
                      <div class="bhz-detail-main">
                        <t t-if="car.main_image">
                          <img t-att-src="'/web/image/bhz.dealer.car/%s/main_image' % car.id" alt="" />
                        </t>
                        <t t-else="">
                          <div class="bhz-car-thumb--placeholder">Sem foto</div>
                        </t>
                      </div>

                      <div class="bhz-gallery mt-3">
                        <t t-foreach="car.image_ids" t-as="img">
                          <div class="bhz-gallery-thumb" t-att-data-img="'/web/image/%s/image' % img.id">
                            <img t-att-src="'/web/image/%s/image' % img.id" alt=""/>
                          </div>
                        </t>
                      </div>
                    </div>

                    <div class="bhz-detail-body">
                      <div class="bhz-detail-head">
                        <h1><t t-esc="car.name"/></h1>
                        <div class="bhz-detail-price">
                          <t t-esc="car.currency_id.symbol"/> <t t-esc="('%.2f' % car.price).replace('.', ',')"/>
                        </div>
                      </div>

                      <div class="bhz-detail-meta">
                        <span><t t-esc="car.year"/></span>
                        <span>•</span>
                        <span><t t-esc="car.mileage_km"/> km</span>
                        <span>•</span>
                        <span><t t-esc="dict(car._fields['fuel'].selection).get(car.fuel)"/></span>
                      </div>

                      <div class="bhz-actions">
                        <t t-set="wa" t-value="car.whatsapp or (car.company_id.phone or '').replace('+','').replace(' ','')"/>
                        <a t-if="wa" class="btn btn-success btn-lg w-100"
                           t-att-href="'https://wa.me/%s?text=%s' % (wa, ('Tenho interesse no carro: %s' % car.name))">
                          Falar no WhatsApp
                        </a>
                        <a t-if="not wa" class="btn btn-primary btn-lg w-100" href="/contactus">Quero atendimento</a>

                        <div class="bhz-muted mt-2">Resposta rápida • Atendimento humano</div>
                      </div>

                      <button type="button" class="btn btn-primary mt-3 w-100 bhz-interest-btn" t-att-data-car-id="car.id" t-att-data-car-name="car.name">Tenho interesse</button>

                      <div class="bhz-desc mt-4">
                        <h3>Descrição</h3>
                        <div t-if="car.description" t-raw="car.description"/>
                        <div t-if="not car.description" class="bhz-muted">Consulte condições e detalhes com a concessionária.</div>

                        <t t-if="car.features">
                          <h3 class="mt-4">Opcionais</h3>
                          <ul class="bhz-features">
                            <t t-foreach="car.features.splitlines()" t-as="f">
                              <t t-if="f.strip()">
                                <li><t t-esc="f"/></li>
                              </t>
                            </t>
                          </ul>
                        </t>
                      </div>
                    </div>
                  </div>

                </div>
              </section>
            </div>
          </t>
        </template>
      </field>
    </record>

    <!-- Página simples: listagem de carros -->
    <record id="view_page_car_list" model="ir.ui.view">
      <field name="name">bhz.dealer.page.car.list</field>
      <field name="type">qweb</field>
      <field name="key">bhz_dealer_website.page_car_list</field>
      <field name="arch" type="xml">
        <template id="page_car_list" name="Carros" page="True">
          <t t-call="website.layout">
            <t t-set="config" t-value="request.env['bhz.dealer.website.config'].sudo().get_for_website(request.website)"/>
            <t t-set="primary" t-value="config.primary_color or '#0d6efd'"/>
            <t t-set="secondary" t-value="config.secondary_color or '#6610f2'"/>
            <div id="wrap" class="container py-4 bhz-dealer"
                 t-att-style="'--bhz-primary:%s;--bhz-secondary:%s;' % (primary, secondary)"
                 t-att-data-bhz-whatsapp="(config.whatsapp or config.phone) and (config.whatsapp or config.phone) or ''"
                 t-att-data-bhz-whatsapp-msg="'Olá, quero saber mais sobre os carros.'">
              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <div>
                  <h1 class="mb-0">Carros</h1>
                  <div class="text-muted"><t t-esc="pager['total'] if pager else len(cars)"/> veículo(s)</div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                  <label class="text-muted small mb-0">Ordenar</label>
                  <form method="get" action="/carros" class="d-flex gap-2">
                    <input type="hidden" name="q" t-att-value="filters.get('q') or ''"/>
                    <input type="hidden" name="brand" t-att-value="filters.get('brand') or ''"/>
                    <input type="hidden" name="model" t-att-value="filters.get('model') or ''"/>
                    <input type="hidden" name="fuel" t-att-value="filters.get('fuel') or ''"/>
                    <input type="hidden" name="condition" t-att-value="filters.get('condition') or ''"/>
                    <input type="hidden" name="transmission" t-att-value="filters.get('transmission') or ''"/>
                    <input type="hidden" name="year_min" t-att-value="filters.get('year_min') or ''"/>
                    <input type="hidden" name="year_max" t-att-value="filters.get('year_max') or ''"/>
                    <input type="hidden" name="price_min" t-att-value="filters.get('price_min') or ''"/>
                    <input type="hidden" name="price_max" t-att-value="filters.get('price_max') or ''"/>
                    <select class="form-select form-select-sm" name="order" onchange="this.form.submit()">
                      <option value="">Destaques e mais novos</option>
                      <option value="price_asc" t-att-selected="1 if filters.get('order')=='price_asc' else None">Preço (menor → maior)</option>
                      <option value="price_desc" t-att-selected="1 if filters.get('order')=='price_desc' else None">Preço (maior → menor)</option>
                      <option value="year_desc" t-att-selected="1 if filters.get('order')=='year_desc' else None">Ano (mais novo)</option>
                      <option value="year_asc" t-att-selected="1 if filters.get('order')=='year_asc' else None">Ano (mais antigo)</option>
                      <option value="newest" t-att-selected="1 if filters.get('order')=='newest' else None">Mais recentes</option>
                    </select>
                  </form>
                </div>
              </div>

              <div class="bhz-stock-layout">
                <div class="bhz-filter-toggle btn btn-outline-secondary d-lg-none">Filtros</div>
                <aside class="bhz-filters">
                  <form action="/carros" method="get" class="bhz-filter-form">
                    <label>Busca</label>
                    <input class="form-control" type="text" name="q" t-att-value="filters.get('q') or ''"/>

                    <label class="mt-2">Marca</label>
                    <select class="form-select" name="brand">
                      <option value="">Todas</option>
                      <t t-foreach="brand_list" t-as="b">
                        <option t-att-value="b" t-att-selected="1 if (filters.get('brand')==b) else None"><t t-esc="b"/></option>
                      </t>
                    </select>

                    <label class="mt-2">Modelo</label>
                    <input class="form-control" type="text" name="model" t-att-value="filters.get('model') or ''"/>

                    <label class="mt-2">Condição</label>
                    <select class="form-select" name="condition">
                      <option value="">Todas</option>
                      <option value="new" t-att-selected="1 if filters.get('condition')=='new' else None">Novo</option>
                      <option value="seminovo" t-att-selected="1 if filters.get('condition')=='seminovo' else None">Seminovo</option>
                      <option value="used" t-att-selected="1 if filters.get('condition')=='used' else None">Usado</option>
                    </select>

                    <label class="mt-2">Combustível</label>
                    <select class="form-select" name="fuel">
                      <option value="">Todos</option>
                      <option value="flex" t-att-selected="1 if filters.get('fuel')=='flex' else None">Flex</option>
                      <option value="gasoline" t-att-selected="1 if filters.get('fuel')=='gasoline' else None">Gasolina</option>
                      <option value="ethanol" t-att-selected="1 if filters.get('fuel')=='ethanol' else None">Etanol</option>
                      <option value="diesel" t-att-selected="1 if filters.get('fuel')=='diesel' else None">Diesel</option>
                      <option value="hybrid" t-att-selected="1 if filters.get('fuel')=='hybrid' else None">Híbrido</option>
                      <option value="electric" t-att-selected="1 if filters.get('fuel')=='electric' else None">Elétrico</option>
                    </select>

                    <label class="mt-2">Câmbio</label>
                    <select class="form-select" name="transmission">
                      <option value="">Todos</option>
                      <option value="manual" t-att-selected="1 if filters.get('transmission')=='manual' else None">Manual</option>
                      <option value="auto" t-att-selected="1 if filters.get('transmission')=='auto' else None">Automático</option>
                      <option value="cvt" t-att-selected="1 if filters.get('transmission')=='cvt' else None">CVT</option>
                    </select>

                    <div class="row mt-2">
                      <div class="col-6">
                        <label>Ano mín</label>
                        <input class="form-control" type="number" name="year_min" t-att-value="filters.get('year_min') or ''"/>
                      </div>
                      <div class="col-6">
                        <label>Ano máx</label>
                        <input class="form-control" type="number" name="year_max" t-att-value="filters.get('year_max') or ''"/>
                      </div>
                    </div>

                    <div class="row mt-2">
                      <div class="col-6">
                        <label>Preço mín</label>
                        <input class="form-control" type="number" step="0.01" name="price_min" t-att-value="filters.get('price_min') or ''"/>
                      </div>
                      <div class="col-6">
                        <label>Preço máx</label>
                        <input class="form-control" type="number" step="0.01" name="price_max" t-att-value="filters.get('price_max') or ''"/>
                      </div>
                    </div>

                    <button class="btn btn-primary w-100 mt-3" type="submit">Aplicar filtros</button>
                    <a class="btn btn-outline-secondary w-100 mt-2" href="/carros">Limpar</a>
                  </form>
                </aside>

                <div class="bhz-stock-grid">
                  <div class="bhz-grid">
                    <t t-if="cars">
                      <t t-foreach="cars" t-as="car">
                        <t t-call="bhz_dealer_website.car_card"/>
                      </t>
                    </t>
                    <t t-else="">
                      <div class="alert alert-info">Nenhum carro encontrado com esses filtros.</div>
                    </t>
                  </div>

                  <t t-if="pager and pager['page_count'] &gt; 1">
                    <div class="mt-3">
                      <t t-call="website.pager">
                        <t t-set="page" t-value="pager['page']"/>
                        <t t-set="page_count" t-value="pager['page_count']"/>
                        <t t-set="step" t-value="pager['step']"/>
                        <t t-set="url" t-value="pager['page_url']"/>
                      </t>
                    </div>
                  </t>
                </div>
              </div>
            </div>
          </t>
        </template>
      </field>
    </record>

    <!-- Página simples: detalhe do carro -->
    <record id="view_page_car_detail" model="ir.ui.view">
      <field name="name">bhz.dealer.page.car.detail</field>
      <field name="type">qweb</field>
      <field name="key">bhz_dealer_website.page_car_detail</field>
      <field name="arch" type="xml">
        <template id="page_car_detail" name="Carro" page="True">
          <t t-call="website.layout">
            <t t-set="config" t-value="request.env['bhz.dealer.website.config'].sudo().get_for_website(request.website)"/>
            <t t-set="primary" t-value="config.primary_color or '#0d6efd'"/>
            <t t-set="secondary" t-value="config.secondary_color or '#6610f2'"/>
            <div id="wrap" class="container py-4 bhz-dealer"
                 t-att-style="'--bhz-primary:%s;--bhz-secondary:%s;' % (primary, secondary)"
                 t-att-data-bhz-whatsapp="(config.whatsapp or config.phone) and (config.whatsapp or config.phone) or ''"
                 t-att-data-bhz-whatsapp-msg="'Olá, quero saber mais sobre os carros.'">
              <a href="/carros" class="text-muted small d-inline-block mb-2">← Voltar</a>
              <h1 class="mb-2"><t t-esc="car.name"/></h1>
              <div class="mb-3 text-muted">
                <t t-if="car.year">Ano: <t t-esc="car.year"/> · </t>
                <t t-if="car.brand"><t t-esc="car.brand"/> </t>
                <t t-if="car.model"><t t-esc="car.model"/></t>
              </div>
              <div class="mb-3">
                <t t-if="car.price">
                  <strong>Preço:</strong>
                  <span><t t-esc="car.currency_id.symbol"/> <t t-esc="'%.2f' % car.price"/></span>
                </t>
              </div>
              <t t-if="car.description">
                <div class="mb-3">
                  <strong>Descrição:</strong>
                  <div t-raw="car.description"/>
                </div>
              </t>
              <t t-if="car.features">
                <div class="mb-3">
                  <strong>Opcionais:</strong>
                  <pre class="mb-0"><t t-esc="car.features"/></pre>
                </div>
              </t>
            </div>
          </t>
        </template>
      </field>
    </record>

    <!-- Página Quem Somos -->
    <record id="view_page_dealer_about" model="ir.ui.view">
      <field name="name">bhz.dealer.page.about</field>
      <field name="type">qweb</field>
      <field name="key">bhz_dealer_website.page_about</field>
      <field name="arch" type="xml">
        <template id="page_about" name="Quem Somos" page="True">
          <t t-call="website.layout">
            <div id="wrap" class="container py-4">
              <h1 class="mb-3">Quem Somos</h1>
              <p>Edite este conteúdo para contar a história da sua concessionária, equipe e diferenciais.</p>
              <p class="text-muted small">Página básica criada pelo módulo BHZ Dealer.</p>
            </div>
          </t>
        </template>
      </field>
    </record>

    <!-- Página Contato -->
    <record id="view_page_dealer_contact" model="ir.ui.view">
      <field name="name">bhz.dealer.page.contact</field>
      <field name="type">qweb</field>
      <field name="key">bhz_dealer_website.page_contact</field>
      <field name="arch" type="xml">
        <template id="page_contact" name="Contato" page="True">
          <t t-call="website.layout">
            <div id="wrap" class="container py-4">
              <h1 class="mb-3">Contato</h1>
              <p>Adicione aqui informações de contato ou um formulário do website builder.</p>
              <p class="text-muted small">Página básica criada pelo módulo BHZ Dealer.</p>
            </div>
          </t>
        </template>
      </field>
    </record>

    <record id="page_about" model="website.page">
      <field name="name">Quem Somos</field>
      <field name="website_id" ref="website.default_website"/>
      <field name="url">/quem-somos</field>
      <field name="view_id" ref="view_page_dealer_about"/>
    </record>

    <record id="page_contact" model="website.page">
      <field name="name">Contato</field>
      <field name="website_id" ref="website.default_website"/>
      <field name="url">/contato</field>
      <field name="view_id" ref="view_page_dealer_contact"/>
    </record>

    <!-- Página home e vínculo como homepage -->
    <record id="page_dealer_home_page" model="website.page">
      <field name="name">Home</field>
      <field name="website_id" ref="website.default_website"/>
      <field name="url">/</field>
      <field name="view_id" ref="view_page_dealer_home"/>
      <field name="is_published">True</field>
    </record>

  </data>
</odoo>
