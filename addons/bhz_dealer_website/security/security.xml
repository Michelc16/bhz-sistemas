<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="group_bhz_dealer_manager" model="res.groups">
    <field name="name">BHZ Dealer / Manager</field>
    <field name="category_id" ref="base.module_category_website"/>
  </record>

  <record id="rule_bhz_dealer_car_company" model="ir.rule">
    <field name="name">Cars: multi-company</field>
    <field name="model_id" ref="model_bhz_dealer_car"/>
    <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    <field name="groups" eval="[(4, ref('group_bhz_dealer_manager'))]"/>
  </record>
</odoo>
