<odoo>
  <record id="view_bhz_seller_ledger_move_tree" model="ir.ui.view">
    <field name="name">bhz.seller.ledger.move.tree</field>
    <field name="model">bhz.seller.ledger.move</field>
    <field name="arch" type="xml">
      <tree>
        <field name="date"/>
        <field name="seller_id"/>
        <field name="move_type"/>
        <field name="amount"/>
        <field name="sale_order_id"/>
        <field name="sale_order_line_id"/>
        <field name="ref"/>
      </tree>
    </field>
  </record>

  <record id="view_bhz_seller_ledger_move_form" model="ir.ui.view">
    <field name="name">bhz.seller.ledger.move.form</field>
    <field name="model">bhz.seller.ledger.move</field>
    <field name="arch" type="xml">
      <form string="Movimento de Ledger">
        <sheet>
          <group>
            <field name="date"/>
            <field name="seller_id"/>
            <field name="move_type"/>
            <field name="amount"/>
            <field name="sale_order_id"/>
            <field name="sale_order_line_id"/>
            <field name="ref"/>
          </group>
          <group>
            <field name="note"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_bhz_seller_ledger_move" model="ir.actions.act_window">
    <field name="name">Ledger</field>
    <field name="res_model">bhz.seller.ledger.move</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>
