<odoo>
  <record id="view_bhz_marketplace_commission_rule_tree" model="ir.ui.view">
    <field name="name">bhz.marketplace.commission.rule.tree</field>
    <field name="model">bhz.marketplace.commission.rule</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="seller_id"/>
        <field name="categ_id"/>
        <field name="commission_rate"/>
        <field name="sequence"/>
        <field name="active"/>
      </list>
    </field>
  </record>

  <record id="view_bhz_marketplace_commission_rule_form" model="ir.ui.view">
    <field name="name">bhz.marketplace.commission.rule.form</field>
    <field name="model">bhz.marketplace.commission.rule</field>
    <field name="arch" type="xml">
      <form string="Regra de comissão">
        <sheet>
          <group>
            <field name="name"/>
            <field name="seller_id"/>
            <field name="categ_id"/>
            <field name="commission_rate"/>
            <field name="sequence"/>
            <field name="active"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_bhz_marketplace_commission_rule" model="ir.actions.act_window">
    <field name="name">Regras de Comissão</field>
    <field name="res_model">bhz.marketplace.commission.rule</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>
