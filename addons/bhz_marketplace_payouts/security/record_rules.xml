<odoo>
  <record id="rule_ledger_seller" model="ir.rule">
    <field name="name">Ledger do seller</field>
    <field name="model_id" ref="model_bhz_seller_ledger_move"/>
    <field name="domain_force">[('seller_id.user_id','=',user.id)]</field>
    <field name="groups" eval="[(4, ref('bhz_marketplace_core.group_marketplace_seller'))]"/>
  </record>

  <record id="rule_payout_seller" model="ir.rule">
    <field name="name">Payout do seller</field>
    <field name="model_id" ref="model_bhz_seller_payout"/>
    <field name="domain_force">[('seller_id.user_id','=',user.id)]</field>
    <field name="groups" eval="[(4, ref('bhz_marketplace_core.group_marketplace_seller'))]"/>
  </record>
</odoo>
