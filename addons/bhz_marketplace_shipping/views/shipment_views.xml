<odoo>
  <record id="view_bhz_seller_shipment_tree" model="ir.ui.view">
    <field name="name">bhz.seller.shipment.tree</field>
    <field name="model">bhz.seller.shipment</field>
    <field name="arch" type="xml">
      <tree>
        <field name="sale_order_id"/>
        <field name="seller_id"/>
        <field name="state"/>
        <field name="tracking_code"/>
        <field name="carrier_id"/>
      </tree>
    </field>
  </record>

  <record id="view_bhz_seller_shipment_form" model="ir.ui.view">
    <field name="name">bhz.seller.shipment.form</field>
    <field name="model">bhz.seller.shipment</field>
    <field name="arch" type="xml">
      <form string="Envio">
        <header>
          <button name="action_ready" type="object" string="Pronto" states="draft"/>
          <button name="action_shipped" type="object" string="Enviar" states="ready"/>
          <button name="action_delivered" type="object" string="Entregue" states="shipped"/>
          <button name="action_cancel" type="object" string="Cancelar" states="draft,ready,shipped"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,ready,shipped,delivered,cancel"/>
        </header>
        <sheet>
          <group>
            <field name="sale_order_id" readonly="1"/>
            <field name="seller_id" readonly="1"/>
            <field name="carrier_id"/>
            <field name="tracking_code"/>
            <field name="note"/>
          </group>
          <field name="line_ids">
            <tree editable="bottom">
              <field name="sale_order_line_id" readonly="1"/>
              <field name="product_id" readonly="1"/>
              <field name="qty" readonly="1"/>
            </tree>
          </field>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_bhz_seller_shipment" model="ir.actions.act_window">
    <field name="name">Envios</field>
    <field name="res_model">bhz.seller.shipment</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>
