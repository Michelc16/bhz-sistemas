<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bhz_football_res_config_settings_website" model="ir.ui.view">
        <field name="name">bhz.football.res.config.settings.website</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='website_id']" position="after">
                <div class="app_settings_block" data-string="Agenda de Jogos">
                    <h2>Agenda de Jogos</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6">
                            <div class="form-group">
                                <label class="col-form-label" for="bhz_football_agenda_enabled">Ativar Agenda de Jogos neste site</label>
                                <div class="o_row">
                                    <field name="bhz_football_agenda_enabled" widget="switch"/>
                                </div>
                                <small class="text-muted">
                                    Cria/remove o menu "Agenda de Jogos" apenas neste website.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
