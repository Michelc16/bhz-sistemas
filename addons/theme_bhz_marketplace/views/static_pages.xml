<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <template id="page_search" name="Busca Marketplace" page="True" url="/marketplace/search">
      <t t-call="website.layout">
        <main id="wrap" class="oe_structure">
          <div class="container py-5">
            <h1 class="h4 mb-3">Busca</h1>
            <p class="text-muted">Use o campo de busca do topo para procurar.</p>
          </div>
        </main>
      </t>
    </template>

    <template id="page_categories" name="Categorias Marketplace" page="True" url="/marketplace/categories">
      <t t-call="website.layout">
        <main id="wrap" class="oe_structure">
          <div class="container py-5">
            <h1 class="h4 mb-3">Categorias</h1>
          </div>
        </main>
      </t>
    </template>

    <template id="page_how_it_works" name="Como funciona" page="True" url="/marketplace/how-it-works">
      <t t-call="website.layout">
        <main id="wrap" class="oe_structure">
          <div class="container py-5">
            <h1 class="h4 mb-3">Como funciona</h1>
          </div>
        </main>
      </t>
    </template>

    <template id="page_become_seller" name="Seja um vendedor" page="True" url="/marketplace/become-a-seller">
      <t t-call="website.layout">
        <main id="wrap" class="oe_structure">
          <div class="container py-5">
            <h1 class="h4 mb-3">Quero vender</h1>
            <p class="text-muted">Cadastro e aprovação do seller (fluxo no bhz_marketplace_core).</p>
            <a class="btn btn-primary" href="/my">Acessar portal</a>
          </div>
        </main>
      </t>
    </template>

  </data>
</odoo>
