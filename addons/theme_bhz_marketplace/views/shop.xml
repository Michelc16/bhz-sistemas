<odoo>
  <template id="page_shop" name="Marketplace Shop">
    <t t-call="website.layout">
      <div class="container py-5">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
          <div>
            <h1 class="h3 mb-1">Loja do Marketplace</h1>
            <p class="text-muted mb-0">Produtos publicados por sellers verificados.</p>
          </div>
          <form class="d-flex gap-2" method="get" action="/marketplace/search">
            <input class="form-control" type="search" name="search" placeholder="Buscar produtos"/>
            <button class="btn btn-primary" type="submit">Buscar</button>
          </form>
        </div>

        <t t-set="products" t-value="request.env['product.template'].sudo().search([('website_published','=',True)], limit=24)"/>
        <div class="row g-3">
          <t t-foreach="products" t-as="p">
            <div class="col-6 col-md-3">
              <a t-att-href="'/marketplace/product?product_id=%s' % p.id" class="card h-100 text-decoration-none shadow-sm">
                <t t-if="p.image_512">
                  <img class="card-img-top" t-att-src="'/web/image/product.template/%s/image_512' % p.id" alt="" style="object-fit:cover; aspect-ratio:1/1;"/>
                </t>
                <div class="card-body">
                  <div class="fw-semibold text-truncate" t-esc="p.name"/>
                  <div class="text-primary fw-bold" t-esc="p.list_price"/>
                  <div class="text-muted small" t-esc="p.bhz_seller_id.name or 'Loja parceira'"/>
                </div>
              </a>
            </div>
          </t>
          <t t-if="not products">
            <div class="col-12">
              <div class="alert alert-info mb-0">Nenhum produto publicado ainda.</div>
            </div>
          </t>
        </div>
      </div>
    </t>
  </template>
</odoo>
