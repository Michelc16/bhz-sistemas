<odoo>
  <record id="view_bhz_connector_job_tree" model="ir.ui.view">
    <field name="name">bhz.connector.job.tree</field>
    <field name="model">bhz.connector.job</field>
    <field name="arch" type="xml">
      <tree>
        <field name="account_id"/>
        <field name="job_type"/>
        <field name="state"/>
        <field name="attempts"/>
        <field name="error"/>
      </tree>
    </field>
  </record>

  <record id="view_bhz_connector_job_form" model="ir.ui.view">
    <field name="name">bhz.connector.job.form</field>
    <field name="model">bhz.connector.job</field>
    <field name="arch" type="xml">
      <form string="Job de conector">
        <header>
          <button name="action_run" string="Executar" type="object" class="btn-primary" states="pending,failed"/>
          <button name="action_retry" string="Reiniciar" type="object" class="btn-secondary" states="failed"/>
          <field name="state" widget="statusbar" statusbar_visible="pending,running,done,failed"/>
        </header>
        <sheet>
          <group>
            <field name="account_id"/>
            <field name="job_type"/>
            <field name="attempts"/>
            <field name="state"/>
          </group>
          <group>
            <field name="payload_json" widget="text"/>
            <field name="error" widget="text"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_bhz_connector_job" model="ir.actions.act_window">
    <field name="name">Jobs</field>
    <field name="res_model">bhz.connector.job</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>
