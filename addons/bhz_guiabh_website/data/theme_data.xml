<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Theme assets (scoped per website when theme applied) -->
    <record id="theme_asset_guiabh_frontend_scss" model="theme.ir.asset">
      <field name="name">GUIABH SCSS (Theme)</field>
      <field name="bundle">web.assets_frontend</field>
      <field name="path">bhz_guiabh_website/static/src/scss/guiabh.scss</field>
      <field name="sequence" eval="10"/>
    </record>
    <record id="theme_asset_guiabh_frontend_js" model="theme.ir.asset">
      <field name="name">GUIABH JS (Theme)</field>
      <field name="bundle">web.assets_frontend</field>
      <field name="path">bhz_guiabh_website/static/src/js/guiabh.js</field>
      <field name="sequence" eval="10"/>
    </record>
    <!-- Ensure assets are also loaded in builder/iframe -->
    <record id="theme_asset_guiabh_wysiwyg_js" model="theme.ir.asset">
      <field name="name">GUIABH JS (Builder)</field>
      <field name="bundle">website.assets_wysiwyg</field>
      <field name="path">bhz_guiabh_website/static/src/js/guiabh.js</field>
      <field name="sequence" eval="10"/>
    </record>

    <!-- Wrapper views for pages (keep full templates in website_templates.xml) -->
    <record id="theme_view_guiabh_home" model="theme.ir.ui.view">
      <field name="name">GuiaBH Home (Theme)</field>
      <field name="key">bhz_guiabh_website.guiabh_home_theme</field>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <t t-name="bhz_guiabh_website.guiabh_home_theme">
          <t t-call="bhz_guiabh_website.guiabh_home"/>
        </t>
      </field>
    </record>
    <record id="theme_view_guiabh_events" model="theme.ir.ui.view">
      <field name="name">GuiaBH Events (Theme)</field>
      <field name="key">bhz_guiabh_website.guiabh_events_theme</field>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <t t-name="bhz_guiabh_website.guiabh_events_theme">
          <t t-call="bhz_guiabh_website.guiabh_events"/>
        </t>
      </field>
    </record>
    <record id="theme_view_guiabh_places" model="theme.ir.ui.view">
      <field name="name">GuiaBH Places (Theme)</field>
      <field name="key">bhz_guiabh_website.guiabh_places_theme</field>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <t t-name="bhz_guiabh_website.guiabh_places_theme">
          <t t-call="bhz_guiabh_website.guiabh_places"/>
        </t>
      </field>
    </record>
    <record id="theme_view_guiabh_agenda" model="theme.ir.ui.view">
      <field name="name">GuiaBH Agenda (Theme)</field>
      <field name="key">bhz_guiabh_website.guiabh_agenda_theme</field>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <t t-name="bhz_guiabh_website.guiabh_agenda_theme">
          <t t-call="bhz_guiabh_website.guiabh_agenda"/>
        </t>
      </field>
    </record>
    <record id="theme_view_guiabh_search" model="theme.ir.ui.view">
      <field name="name">GuiaBH Search (Theme)</field>
      <field name="key">bhz_guiabh_website.guiabh_search_theme</field>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <t t-name="bhz_guiabh_website.guiabh_search_theme">
          <t t-call="bhz_guiabh_website.guiabh_search"/>
        </t>
      </field>
    </record>
    <record id="theme_view_guiabh_favorites" model="theme.ir.ui.view">
      <field name="name">GuiaBH Favorites (Theme)</field>
      <field name="key">bhz_guiabh_website.guiabh_favorites_theme</field>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <t t-name="bhz_guiabh_website.guiabh_favorites_theme">
          <t t-call="bhz_guiabh_website.guiabh_favorites"/>
        </t>
      </field>
    </record>
    <record id="theme_view_guiabh_thanks" model="theme.ir.ui.view">
      <field name="name">GuiaBH Thanks (Theme)</field>
      <field name="key">bhz_guiabh_website.guiabh_thanks_theme</field>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <t t-name="bhz_guiabh_website.guiabh_thanks_theme">
          <t t-call="bhz_guiabh_website.guiabh_thanks"/>
        </t>
      </field>
    </record>

    <!-- Theme pages -->
    <record id="theme_page_guiabh_home" model="theme.website.page">
      <field name="name">GuiaBH Home</field>
      <field name="url">/</field>
      <field name="view_id" ref="theme_view_guiabh_home"/>
      <field name="is_published" eval="True"/>
      <field name="is_new_page_template" eval="True"/>
    </record>
    <record id="theme_page_guiabh_events" model="theme.website.page">
      <field name="name">GuiaBH Eventos</field>
      <field name="url">/eventos</field>
      <field name="view_id" ref="theme_view_guiabh_events"/>
      <field name="is_published" eval="True"/>
    </record>
    <record id="theme_page_guiabh_places" model="theme.website.page">
      <field name="name">GuiaBH Lugares</field>
      <field name="url">/lugares</field>
      <field name="view_id" ref="theme_view_guiabh_places"/>
      <field name="is_published" eval="True"/>
    </record>
    <record id="theme_page_guiabh_agenda" model="theme.website.page">
      <field name="name">GuiaBH Agenda</field>
      <field name="url">/agenda</field>
      <field name="view_id" ref="theme_view_guiabh_agenda"/>
      <field name="is_published" eval="True"/>
    </record>
    <record id="theme_page_guiabh_search" model="theme.website.page">
      <field name="name">GuiaBH Buscar</field>
      <field name="url">/buscar</field>
      <field name="view_id" ref="theme_view_guiabh_search"/>
      <field name="is_published" eval="True"/>
    </record>
    <record id="theme_page_guiabh_favorites" model="theme.website.page">
      <field name="name">GuiaBH Favoritos</field>
      <field name="url">/favoritos</field>
      <field name="view_id" ref="theme_view_guiabh_favorites"/>
      <field name="is_published" eval="True"/>
    </record>
    <record id="theme_page_guiabh_thanks" model="theme.website.page">
      <field name="name">GuiaBH Obrigado</field>
      <field name="url">/obrigado</field>
      <field name="view_id" ref="theme_view_guiabh_thanks"/>
      <field name="is_published" eval="True"/>
    </record>

    <!-- Theme menus -->
    <record id="theme_menu_guiabh_root" model="theme.website.menu">
      <field name="name">GuiaBH</field>
      <field name="url">/</field>
    </record>
    <record id="theme_menu_guiabh_eventos" model="theme.website.menu">
      <field name="name">Eventos</field>
      <field name="url">/eventos</field>
      <field name="parent_id" ref="theme_menu_guiabh_root"/>
      <field name="sequence" eval="10"/>
    </record>
    <record id="theme_menu_guiabh_lugares" model="theme.website.menu">
      <field name="name">Lugares</field>
      <field name="url">/lugares</field>
      <field name="parent_id" ref="theme_menu_guiabh_root"/>
      <field name="sequence" eval="20"/>
    </record>
    <record id="theme_menu_guiabh_oquefazer" model="theme.website.menu">
      <field name="name">O que fazer</field>
      <field name="url">/eventos</field>
      <field name="parent_id" ref="theme_menu_guiabh_root"/>
      <field name="sequence" eval="30"/>
    </record>
    <record id="theme_menu_guiabh_guias" model="theme.website.menu">
      <field name="name">Guias</field>
      <field name="url">/guias/fim-de-semana</field>
      <field name="parent_id" ref="theme_menu_guiabh_root"/>
      <field name="sequence" eval="40"/>
    </record>
    <record id="theme_menu_guiabh_today" model="theme.website.menu">
      <field name="name">Hoje</field>
      <field name="url">/eventos?when=today</field>
      <field name="parent_id" ref="theme_menu_guiabh_oquefazer"/>
      <field name="sequence" eval="10"/>
    </record>
    <record id="theme_menu_guiabh_weekend" model="theme.website.menu">
      <field name="name">Fim de semana</field>
      <field name="url">/eventos?when=weekend</field>
      <field name="parent_id" ref="theme_menu_guiabh_oquefazer"/>
      <field name="sequence" eval="20"/>
    </record>
    <record id="theme_menu_guiabh_free" model="theme.website.menu">
      <field name="name">Gratuitos</field>
      <field name="url">/eventos?free=1</field>
      <field name="parent_id" ref="theme_menu_guiabh_oquefazer"/>
      <field name="sequence" eval="30"/>
    </record>

    <!-- Snippets registered as theme view -->
    <record id="theme_view_guiabh_snippets" model="theme.ir.ui.view">
      <field name="name">GuiaBH Snippets (Theme)</field>
      <field name="key">bhz_guiabh_website.guiabh_snippets_theme</field>
      <field name="mode">extension</field>
      <field name="arch" type="xml">
        <templates xml:space="preserve">
          <template id="s_guiabh_hero_search" name="Hero GuiaBH" page="true">
              <section class="guiabh-hero" data-snippet="s_guiabh_hero_search" data-name="Hero GuiaBH" data-oe-shape-data='"{}"'>
                  <div class="guia-container hero-grid">
                      <div>
                          <h1>Planeje sua semana em BH</h1>
                          <p>Busque eventos, shows, teatros e lugares incríveis em segundos.</p>
                          <div class="search-box">
                              <form action="/eventos" method="get">
                                  <input type="search" name="q" placeholder="Buscar eventos, artistas ou bairros" aria-label="Buscar"/>
                                  <button type="submit" class="btn btn-primary btn-guiabh">Buscar</button>
                              </form>
                              <div class="hero-chips js-guiabh-chip-filter" data-base-url="/eventos">
                                  <a class="hero-chip js-chip" data-param="when" data-value="today">Hoje</a>
                                  <a class="hero-chip js-chip" data-param="when" data-value="tomorrow">Amanhã</a>
                                  <a class="hero-chip js-chip" data-param="when" data-value="weekend">Fim de semana</a>
                                  <a class="hero-chip js-chip" data-param="free" data-value="1">Gratuitos</a>
                              </div>
                          </div>
                      </div>
                      <div>
                          <img src="/bhz_guiabh_website/static/src/img/placeholders/editorial_placeholder.svg" class="img img-fluid" alt="Hero GuiaBH"/>
                      </div>
                  </div>
              </section>
          </template>

          <template id="s_guiabh_featured_events_carousel" name="Eventos em destaque" page="true">
              <section class="py-5" data-snippet="s_guiabh_featured_events_carousel" data-name="Eventos em destaque" data-limit="6" data-show-price="true" data-js="GuiabhEventsOptions">
                  <div class="guia-container">
                      <div class="guiabh-section-title">
                          <h2>Eventos em destaque</h2>
                          <a href="/eventos">Ver agenda</a>
                      </div>
                      <div class="guiabh-carousel js-guiabh-dynamic" data-type="events" data-layout="carousel"></div>
                  </div>
              </section>
          </template>

          <template id="s_guiabh_events_grid" name="Grid de eventos" page="true">
              <section class="py-5" data-snippet="s_guiabh_events_grid" data-name="Grid de eventos" data-limit="6" data-show-price="true" data-js="GuiabhEventsOptions">
                  <div class="guia-container">
                      <div class="guiabh-section-title">
                          <h2>Eventos</h2>
                          <a href="/eventos">Ver todos</a>
                      </div>
                      <div class="guiabh-grid js-guiabh-dynamic" data-type="events" data-layout="grid"></div>
                  </div>
              </section>
          </template>

          <template id="s_guiabh_places_grid" name="Grid de lugares" page="true">
              <section class="py-5" data-snippet="s_guiabh_places_grid" data-name="Grid de lugares" data-limit="6" data-js="GuiabhPlacesOptions">
                  <div class="guia-container">
                      <div class="guiabh-section-title">
                          <h2>Lugares</h2>
                          <a href="/lugares">Explorar</a>
                      </div>
                      <div class="guiabh-grid js-guiabh-dynamic" data-type="places" data-layout="grid"></div>
                  </div>
              </section>
          </template>

          <template id="s_guiabh_editorial_cards" name="Cards editoriais" page="true">
              <section class="py-5" data-snippet="s_guiabh_editorial_cards" data-name="Editorial/Guias">
                  <div class="guia-container">
                      <div class="guiabh-section-title">
                          <h2>Guias e dicas</h2>
                      </div>
                      <div class="guiabh-grid">
                          <div class="guiabh-card">
                              <div class="cover"><img src="/bhz_guiabh_website/static/src/img/placeholders/editorial_placeholder.svg" alt="Guia gratuito"/></div>
                              <div class="content">
                                  <h3>Agenda gratuita da semana</h3>
                                  <p class="text-muted">Eventos que cabem em qualquer bolso.</p>
                                  <div class="footer"><a href="/eventos?free=1" class="btn btn-link">Abrir</a></div>
                              </div>
                          </div>
                          <div class="guiabh-card">
                              <div class="cover"><img src="/bhz_guiabh_website/static/src/img/placeholders/place_placeholder.svg" alt="Roteiro gastronômico"/></div>
                              <div class="content">
                                  <h3>Roteiro gastronômico</h3>
                                  <p class="text-muted">Escolha fácil para um date.</p>
                                    <div class="footer"><a href="/lugares?tipo=restaurantes" class="btn btn-link">Explorar</a></div>
                              </div>
                          </div>
                          <div class="guiabh-card">
                              <div class="cover"><img src="/bhz_guiabh_website/static/src/img/placeholders/event_placeholder.svg" alt="Eventos ao ar livre"/></div>
                              <div class="content">
                                  <h3>Ao ar livre</h3>
                                  <p class="text-muted">Praças, parques e shows abertos.</p>
                                    <div class="footer"><a href="/eventos?reg=pampulha" class="btn btn-link">Ver opções</a></div>
                              </div>
                          </div>
                      </div>
                  </div>
              </section>
          </template>

          <template id="guiabh_snippets" inherit_id="website.snippets">
              <xpath expr="//div[@id='snippet_structure']/div" position="inside">
                  <t t-snippet="bhz_guiabh_website.s_guiabh_hero_search" t-thumbnail="/bhz_guiabh_website/static/src/img/placeholders/editorial_placeholder.svg"/>
                  <t t-snippet="bhz_guiabh_website.s_guiabh_featured_events_carousel" t-thumbnail="/bhz_guiabh_website/static/src/img/placeholders/event_placeholder.svg"/>
                  <t t-snippet="bhz_guiabh_website.s_guiabh_events_grid" t-thumbnail="/bhz_guiabh_website/static/src/img/placeholders/event_placeholder.svg"/>
                  <t t-snippet="bhz_guiabh_website.s_guiabh_places_grid" t-thumbnail="/bhz_guiabh_website/static/src/img/placeholders/place_placeholder.svg"/>
                  <t t-snippet="bhz_guiabh_website.s_guiabh_editorial_cards" t-thumbnail="/bhz_guiabh_website/static/src/img/placeholders/editorial_placeholder.svg"/>
              </xpath>
          </template>

          <template id="guiabh_snippet_options" inherit_id="website.snippet_options">
              <xpath expr="//we-snippet[@name='Dynamic Content']" position="inside">
                  <we-snippet name="Eventos GuiaBH" t-select="[data-snippet='s_guiabh_events_grid'],[data-snippet='s_guiabh_featured_events_carousel']">
                      <we-button string="6 itens" data-name="limit6"/>
                      <we-button string="9 itens" data-name="limit9"/>
                      <we-button string="12 itens" data-name="limit12"/>
                      <we-separator/>
                      <we-button string="Mostrar preço" data-name="togglePrice" data-param="true"/>
                      <we-button string="Ocultar preço" data-name="togglePrice" data-param="false"/>
                  </we-snippet>
                  <we-snippet name="Lugares GuiaBH" t-select="[data-snippet='s_guiabh_places_grid']">
                      <we-button string="6 lugares" data-name="limit6"/>
                      <we-button string="9 lugares" data-name="limit9"/>
                      <we-button string="12 lugares" data-name="limit12"/>
                  </we-snippet>
              </xpath>
          </template>
        </templates>
      </field>
    </record>
  </data>
</odoo>
