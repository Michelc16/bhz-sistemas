<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Views -->
    <record id="view_guiabh_category_list" model="ir.ui.view">
        <field name="name">guiabh.category.list</field>
        <field name="model">guiabh.category</field>
        <field name="arch" type="xml">
            <list string="Categorias">
                <field name="name"/>
                <field name="parent_id"/>
                <field name="featured"/>
                <field name="website_published"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="slug"/>
            </list>
        </field>
    </record>

    <record id="view_guiabh_category_form" model="ir.ui.view">
        <field name="name">guiabh.category.form</field>
        <field name="model">guiabh.category</field>
        <field name="arch" type="xml">
            <form string="Categoria">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_id"/>
                            <field name="featured"/>
                            <field name="website_published"/>
                            <field name="slug"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="website_meta_title"/>
                            <field name="website_meta_description"/>
                            <field name="cover_image"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrição">
                            <field name="description"/>
                        </page>
                        <page string="SEO">
                            <group>
                                <field name="website_meta_title"/>
                                <field name="website_meta_description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_guiabh_category_kanban" model="ir.ui.view">
        <field name="name">guiabh.category.kanban</field>
        <field name="model">guiabh.category</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" default_group_by="parent_id">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_primary_left">
                                <field name="name"/>
                            </div>
                            <div class="o_kanban_secondary_left">
                                <field name="parent_id"/>
                            </div>
                            <div class="o_kanban_primary_right">
                                <field name="website_published"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_guiabh_category_search" model="ir.ui.view">
        <field name="name">guiabh.category.search</field>
        <field name="model">guiabh.category</field>
        <field name="arch" type="xml">
            <search string="Pesquisar Categorias">
                <field name="name"/>
                <field name="parent_id"/>
                <filter string="Destacadas" name="featured" domain="[('featured','=',True)]"/>
                <filter string="Publicado" name="published" domain="[('website_published','=',True)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_guiabh_category" model="ir.actions.act_window">
        <field name="name">Categorias</field>
        <field name="res_model">guiabh.category</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_guiabh_category_search"/>
    </record>
</odoo>
