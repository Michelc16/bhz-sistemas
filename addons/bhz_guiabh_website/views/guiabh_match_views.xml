<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_guiabh_match_list" model="ir.ui.view">
        <field name="name">guiabh.match.list</field>
        <field name="model">guiabh.match</field>
        <field name="arch" type="xml">
            <list string="Jogos">
                <field name="name"/>
                <field name="category_id"/>
                <field name="match_datetime"/>
                <field name="venue"/>
                <field name="featured"/>
                <field name="website_published"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="slug"/>
            </list>
        </field>
    </record>

    <record id="view_guiabh_match_form" model="ir.ui.view">
        <field name="name">guiabh.match.form</field>
        <field name="model">guiabh.match</field>
        <field name="arch" type="xml">
            <form string="Jogo">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category_id"/>
                            <field name="match_datetime"/>
                            <field name="venue"/>
                        </group>
                        <group>
                            <field name="featured"/>
                            <field name="website_published"/>
                            <field name="slug"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="cover_image"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrição">
                            <field name="description"/>
                        </page>
                        <page string="SEO">
                            <group>
                                <field name="website_meta_title"/>
                                <field name="website_meta_description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_guiabh_match_kanban" model="ir.ui.view">
        <field name="name">guiabh.match.kanban</field>
        <field name="model">guiabh.match</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_primary_left">
                                <field name="name"/>
                            </div>
                            <div class="o_kanban_secondary_left">
                                <field name="match_datetime"/>
                            </div>
                            <div class="o_kanban_primary_right">
                                <field name="website_published"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_guiabh_match_search" model="ir.ui.view">
        <field name="name">guiabh.match.search</field>
        <field name="model">guiabh.match</field>
        <field name="arch" type="xml">
            <search string="Pesquisar Jogos">
                <field name="name"/>
                <field name="category_id"/>
                <filter string="Destacados" name="featured" domain="[('featured','=',True)]"/>
                <filter string="Publicados" name="published" domain="[('website_published','=',True)]"/>
            </search>
        </field>
    </record>

    <record id="action_guiabh_match" model="ir.actions.act_window">
        <field name="name">Jogos</field>
        <field name="res_model">guiabh.match</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_guiabh_match_search"/>
    </record>
</odoo>
