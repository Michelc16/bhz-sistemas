<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_guiabh_ad_tree" model="ir.ui.view">
    <field name="name">guiabh.ad.tree</field>
    <field name="model">guiabh.ad</field>
    <field name="arch" type="xml">
      <list string="Anúncios">
        <field name="active" widget="boolean_toggle"/>
        <field name="name"/>
        <field name="position"/>
        <field name="website_id"/>
        <field name="start_date"/>
        <field name="end_date"/>
        <field name="sequence"/>
      </list>
    </field>
  </record>

  <record id="view_guiabh_ad_form" model="ir.ui.view">
    <field name="name">guiabh.ad.form</field>
    <field name="model">guiabh.ad</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="active"/>
            <field name="name"/>
            <field name="position"/>
            <field name="website_id"/>
          </group>
          <group>
            <field name="start_date"/>
            <field name="end_date"/>
            <field name="sequence"/>
          </group>
          <group>
            <field name="image" widget="image"/>
            <field name="link_url"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_guiabh_ad" model="ir.actions.act_window">
    <field name="name">Anúncios</field>
    <field name="res_model">guiabh.ad</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_guiabh_ads" name="Anúncios" parent="website.menu_website_configuration" action="action_guiabh_ad" sequence="80"/>
</odoo>
