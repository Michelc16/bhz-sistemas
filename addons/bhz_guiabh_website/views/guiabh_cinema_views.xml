<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_guiabh_cinema_movie_tree" model="ir.ui.view">
      <field name="name">guiabh.cinema.movie.tree</field>
      <field name="model">guiabh.cinema.movie</field>
      <field name="arch" type="xml">
        <tree string="Filmes" create="true">
          <field name="name"/>
          <field name="category"/>
          <field name="genre"/>
          <field name="age_rating"/>
          <field name="release_date"/>
          <field name="is_featured"/>
          <field name="website_published"/>
        </tree>
      </field>
    </record>

    <record id="view_guiabh_cinema_movie_form" model="ir.ui.view">
      <field name="name">guiabh.cinema.movie.form</field>
      <field name="model">guiabh.cinema.movie</field>
      <field name="arch" type="xml">
        <form string="Filme">
          <sheet>
            <group>
              <group>
                <field name="name"/>
                <field name="category"/>
                <field name="genre"/>
                <field name="age_rating"/>
                <field name="release_date"/>
                <field name="is_featured"/>
                <field name="website_published"/>
                <field name="website_id"/>
              </group>
              <group>
                <field name="poster_image" widget="image" class="oe_avatar"/>
                <field name="cineart_url"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_guiabh_cinema_movie" model="ir.actions.act_window">
      <field name="name">Filmes (Cinema)</field>
      <field name="res_model">guiabh.cinema.movie</field>
      <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_guiabh_cinema_root"
              name="Cinema"
              parent="bhz_guiabh_website.menu_guiabh_root"
              sequence="40"/>
    <menuitem id="menu_guiabh_cinema_movies"
              name="Filmes"
              parent="menu_guiabh_cinema_root"
              action="action_guiabh_cinema_movie"
              sequence="10"/>
  </data>
</odoo>
