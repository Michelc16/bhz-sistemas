<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Server action to trigger Cineart sync from inside bhz_guiabh_website -->
    <record id="action_guiabh_cineart_sync_proxy" model="ir.actions.server">
      <field name="name">Sincronizar Cineart (GuiaBH)</field>
      <field name="model_id" ref="bhz_cineart.model_guiabh_cineart_movie"/>
      <field name="state">code</field>
      <field name="code">action = env['guiabh.cineart.movie'].action_sync_all_now()</field>
    </record>

    <!-- Menu entry reusing Cineart movie action -->
    <menuitem id="menu_guiabh_cineart_root_proxy"
              name="Cinema"
              parent="guiabh_event.menu_guiabh_root"
              sequence="50"/>
    <menuitem id="menu_guiabh_cineart_movies_proxy"
              name="Filmes (Cineart)"
              parent="menu_guiabh_cineart_root_proxy"
              action="bhz_cineart.action_guiabh_cineart_movie"
              sequence="10"/>
    <menuitem id="menu_guiabh_cineart_sync_proxy"
              name="Sincronizar agora"
              parent="menu_guiabh_cineart_root_proxy"
              action="action_guiabh_cineart_sync_proxy"
              sequence="20"/>
  </data>
</odoo>
