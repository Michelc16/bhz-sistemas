<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_guiabh_news_list" model="ir.ui.view">
        <field name="name">guiabh.news.list</field>
        <field name="model">guiabh.news</field>
        <field name="arch" type="xml">
            <list string="Notícias">
                <field name="name"/>
                <field name="category_id"/>
                <field name="publish_date"/>
                <field name="author_name"/>
                <field name="featured"/>
                <field name="website_published"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="slug"/>
            </list>
        </field>
    </record>

    <record id="view_guiabh_news_form" model="ir.ui.view">
        <field name="name">guiabh.news.form</field>
        <field name="model">guiabh.news</field>
        <field name="arch" type="xml">
            <form string="Notícia">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category_id"/>
                            <field name="publish_date"/>
                            <field name="author_name"/>
                        </group>
                        <group>
                            <field name="featured"/>
                            <field name="website_published"/>
                            <field name="slug"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="cover_image"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Conteúdo">
                            <field name="description"/>
                        </page>
                        <page string="SEO">
                            <group>
                                <field name="website_meta_title"/>
                                <field name="website_meta_description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_guiabh_news_kanban" model="ir.ui.view">
        <field name="name">guiabh.news.kanban</field>
        <field name="model">guiabh.news</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_primary_left">
                                <field name="name"/>
                            </div>
                            <div class="o_kanban_secondary_left">
                                <field name="publish_date"/>
                            </div>
                            <div class="o_kanban_primary_right">
                                <field name="website_published"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_guiabh_news_search" model="ir.ui.view">
        <field name="name">guiabh.news.search</field>
        <field name="model">guiabh.news</field>
        <field name="arch" type="xml">
            <search string="Pesquisar Notícias">
                <field name="name"/>
                <field name="category_id"/>
                <filter string="Destacadas" name="featured" domain="[('featured','=',True)]"/>
                <filter string="Publicadas" name="published" domain="[('website_published','=',True)]"/>
            </search>
        </field>
    </record>

    <record id="action_guiabh_news" model="ir.actions.act_window">
        <field name="name">Notícias</field>
        <field name="res_model">guiabh.news</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_guiabh_news_search"/>
    </record>
</odoo>
