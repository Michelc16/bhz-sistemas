<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bhz_event_promo_res_config_settings_view" model="ir.ui.view">
        <field name="name">bhz_event_promo.res.config.settings.view</field>
        <field name="model">res.config.settings</field>
        <field name="active" eval="False"/>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block" data-string="Carrossel de Destaques" string="Carrossel de Destaques">
                    <h2>Carrossel de Destaques</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6">
                            <div class="alert alert-info" role="alert">
                                As configurações do carrossel estão disponíveis no próprio snippet do Website Builder.
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
